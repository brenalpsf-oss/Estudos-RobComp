        #        self.objeto_focado_nome = det.classname
        #        self.objeto_focado_centro_x = (det.xmin + det.xmax) / 2
        pass

    # --- MÁQUINA DE ESTADOS ---

    def girando(self):
        """Faz o robô rodar no próprio eixo procurando figuras"""
        # Critério de parada de 360 graus da volta completa (Rúbrica 2)
        if self.total_girado >= 360.0:
            self.robot_state = 'finalizado'
            return

        # Se encontrou um objeto válido que ainda não foi registrado, vai centralizar
        if self.objeto_focado_nome is not None:
            self.robot_state = 'centralizando'
            return

        self.twist.linear.x = 0.0
        self.twist.angular.z = 0.2  # Rotação suave para não borrar a imagem

    def centralizando(self):
        """Ajusta a rotação para alinhar o objeto exatamente com o meio da câmera"""
        if self.objeto_focado_centro_x is None:
            self.robot_state = 'girando'
            return

        erro = self.imagem_largura_centro - self.objeto_focado_centro_x
        
        # Se o erro de pixel for muito baixo, o objeto está centralizado!
        if abs(erro) < 5:
            self.robot_state = 'coletando'
        else:
            # Controle proporcional simples para centralizar
            self.twist.linear.x = 0.0
            self.twist.angular.z = 0.005 * erro 

    def coletando(self):
        """Para totalmente o robô e faz o registro oficial do ângulo usando logs do ROS 2"""
        self.twist.linear.x = 0.0
        self.twist.angular.z = 0.0
        
        # Garante o requisito da Rúbrica 4: IMPRIME a figura e o valor angular em graus
        angulo_final = self.yaw_atual_graus
        self.figuras_detectadas[self.objeto_focado_nome] = round(angulo_final, 1)
        
        self.get_logger().info(f'FIGURA DETECTADA: {self.objeto_focado_nome} na posição angular: {angulo_final:.1f}°')

        # Limpa as miras para o robô voltar a procurar as próximas figuras
        self.objeto_focado_nome = None
        self.objeto_focado_centro_x = None
        
        # Retorna para o estado de giro
        self.robot_state = 'girando'

    def finalizado(self):
        """Fim do circuito de 360 graus: exibe o dicionário final exigido no item 5"""
        self.twist.linear.x = 0.0
        self.twist.angular.z = 0.0
        
        # Imprime o dicionário completo das posições mapeadas
        self.get_logger().info(f'Dicionário Final de Posições Angulares: {self.figuras_detectadas}')

    def control(self):
        """Gerenciador cíclico do base_control"""
        self.state_machine[self.robot_state]()
        if self.robot_state not in self.estados_clientes:
            self.cmd_vel_pub.publish(self.twist)

def main(args=None):
    rclpy.init(args=args)
    ros_node = EstimaPosicao()

    while rclpy.ok() and ros_node.robot_state != 'finalizado':
        rclpy.spin_once(ros_node)

    # Executa uma última vez para garantir o print do estado finalizado
    rclpy.spin_once(ros_node)
    
    ros_node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()