class EstimaPosicao(Node):
    def __init__(self):
        # REQUISITO 3: Nome do nó exato exigido pelo enunciado
        super().__init__('estima_posicao_node')

        # --- MÁQUINA DE ESTADOS ---
        # girando: rotaciona procurando por novas figuras
        # centralizando: ajusta o foco fino para deixar a figura no meio da imagem
        # coletando: para totalmente os motores e registra o ângulo
        # finalizado: completou 360 graus, exibe o dicionário e para
        self.robot_state = 'girando'
        self.state_machine = {
            'girando': self.girando,
            'centralizando': self.centralizando,
            'coletando': self.coletando,
            'finalizado': self.finalizado
        }
        self.estados_clientes = []

        # --- VARIÁVEIS DE CONTROLE EM GRAUS ---
        self.twist = Twist()
        self.yaw_atual_graus = 0.0
        self.yaw_inicial_graus = None
        self.total_girado = 0.0
        self.ultimo_yaw = 0.0

        # --- DICIONÁRIO DE RESULTADOS ---
        self.figuras_detectadas = {} # Guardará {"nome_objeto": angulo_graus}
        
        # Alvos procurados conforme especificação do item 4
        self.alvos_obrigatorios = ["cat", "dog", "car", "bicycle", "person"]

        # Variáveis auxiliares de detecção visual
        self.objeto_focado_nome = None
        self.objeto_focado_centro_x = None
        self.imagem_largura_centro = 320 # Centro padrão para resoluções de 640x480

        # --- SUBSCRIBERS E PUBLISHERS ---
        self.odom_sub = self.create_subscription(Odometry, '/odom', self.odom_callback, 10)
        
        # Subscriber de imagem comprimida (comum no turtlebot simulado)
        self.image_sub = self.create_subscription(
            CompressedImage, 
            '/camera/image_raw/compressed', 
            self.image_callback, 
            QoSProfile(depth=10, reliability=ReliabilityPolicy.BEST_EFFORT)
        )
        
        self.cmd_vel_pub = self.create_publisher(Twist, 'cmd_vel', 10)

        # Timer cíclico de controle (10Hz)
        self.timer = self.create_timer(0.1, self.control)
        self.get_logger().info('Nó de Estimação Angular Ativo!')

    def quat_to_euler_yaw(self, x, y, z, w):
        """Converte quatérnios de orientação para ângulo Yaw (Z) em radianos"""
        siny_cosp = 2 * (w * z + x * y)
        cosy_cosp = 1 - 2 * (y * y + z * z)
        return np.arctan2(siny_cosp, cosy_cosp)

    def odom_callback(self, msg: Odometry):
        """Mapeia o ângulo atual do robô escalonado estritamente de 0 a 360 graus"""
        q = msg.pose.pose.orientation
        yaw_rad = self.quat_to_euler_yaw(q.x, q.y, q.z, q.w)
        
        # Converte para graus e joga no intervalo [0, 360)
        graus = np.degrees(yaw_rad)
        if graus < 0:
            graus += 360.0
            
        self.yaw_atual_graus = graus

        # Inicializa o marcador angular na primeira leitura
        if self.yaw_inicial_graus is None:
            self.yaw_inicial_graus = self.yaw_atual_graus
            self.ultimo_yaw = self.yaw_atual_graus
            return

        # Calcula o acúmulo real da rotação desconsiderando o estouro de 360 para 0
        diff = self.yaw_atual_graus - self.ultimo_yaw
        if diff > 180:
            diff -= 360
        elif diff < -180:
            diff += 360
            
        self.total_girado += abs(diff)
        self.ultimo_yaw = self.yaw_atual_graus

    def image_callback(self, msg):
        """Processa a visão para identificar a presença de objetos"""
        # ⚠️ Nota de Prova: Aqui você usaria o módulo de detecção padrão da sua matéria 
